{
  "harness": "claude",
  "projectName": "Tinyman",
  "projectDesc": "AI Agent 平台",
  "imPlatform": "lark",
  "pollInterval": 1,
  "pollCooldown": 15,
  "dirs": {
    "repos": "repos",
    "knowledge": "knowledge-base",
    "messages": "messages",
    "tasks": "tasks",
    "worklogs": "worklogs"
  },
  "agents": [
    {
      "session": "gateway-agent",
      "identity": "gateway",
      "stalenessSec": 180,
      "watch": { "dir": "messages", "cmd": "读msg并lark回复" }
    },
    {
      "session": "code-analyzer",
      "identity": "code-analyzer",
      "stalenessSec": 300,
      "watch": { "dir": "tasks", "pattern": "code-req-*.json", "cmd": "读tasks并分析代码写结果" }
    },
    {
      "session": "code-review-agent",
      "identity": "code-review-agent",
      "stalenessSec": 300,
      "watch": { "dir": "tasks", "pattern": "review-req-*.json", "cmd": "读tasks/review-req并审查代码" }
    },
    {
      "session": "deploy-monitor",
      "identity": "deploy-monitor",
      "stalenessSec": 300,
      "watch": { "dir": "tasks", "pattern": "deploy-req-*.json", "cmd": "读tasks/deploy-req并巡检发布" }
    }
  ]
}
