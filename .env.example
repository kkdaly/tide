# AI Agent 平台配置 — 复制为 .env 并填入你的信息

# Harness: claude / codex / trae / openclaw
HARNESS=claude

# 项目名称（出现在 Agent 自我介绍中）
PROJECT_NAME=我的项目

# 项目简介（一句话）
PROJECT_DESC=一个需要技术支持的在线服务

# IM 平台: lark / slack / custom
IM_PLATFORM=lark

# 代码仓库路径（Agent 读代码用，相对于项目根目录或绝对路径）
REPOS_DIR=repos

# 知识库目录
KNOWLEDGE_DIR=knowledge-base

# 消息落地目录
MESSAGES_DIR=messages

# Worklog 目录
WORKLOG_DIR=worklogs

# msg-watcher 轮询间隔（秒），默认 1
POLL_INTERVAL=1

# 唤醒冷却时间（秒），防止重复唤醒，默认 15
POLL_COOLDOWN=30

# ============ Lark 配置（IM_PLATFORM=lark 时必填）============
# 飞书 App ID 和 Secret（lark-cli config init 后自动生成，见 ~/.lark/）
# LARK_APP_ID=
# LARK_APP_SECRET=
